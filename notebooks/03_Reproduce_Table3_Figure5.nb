  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"params0", "=", 
     RowBox[{"CVTPulley`TypesAndValidation`MakeParameters", "[", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<rMin\>\"", "->", "10"}], ",", 
