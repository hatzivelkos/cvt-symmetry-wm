        RowBox[{"\"\<exportBaseName\>\"", "->", "\"\<example3\>\""}]}], 
       "|>"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"params", "=", 
     RowBox[{
     "CVTPulley`BeltLength`SetReferenceBeltLength", "[", "params0", "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Reference belt length L0 = \>\"", ",", 
      RowBox[{"NumberForm", "[", 
       RowBox[{
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"params", "[", "\"\<beltLength\>\"", "]"}], ",", "12"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"12", ",", "7"}], "}"}]}], "]"}]}], "]"}], ";"}], 
