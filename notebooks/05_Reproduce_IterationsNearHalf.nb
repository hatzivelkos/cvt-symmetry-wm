Notebook[{
Cell["\<\

CVTPulley \[LongDash] Reproduce convergence table near t = 0.5

This notebook reproduces the supplementary convergence table reporting the
number of iterations required to reach the stopping tolerance near t = 0.5.

The table is intended to complement the convergence discussion in the article
by providing a compact quantitative illustration of the mild slowdown of the
symmetrization procedure in the vicinity of the midpoint.

Before using this notebook, evaluate 00_LoadProject.nb so that the package
is loaded.\
\>", "Text",
 CellChangeTimes->{{3.982768289181795*^9, 3.9827683025505867`*^9}, {
  3.982821068836014*^9, 
  3.9828210965580807`*^9}},ExpressionUUID->"f9ba541d-0552-7d44-b122-\
d4473fc37dff"],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{{3.9828186104104385`*^9, 
  3.982818639691164*^9}},ExpressionUUID->"ada513b8-2479-fe49-be84-\
8403c4745d6a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"::", "Section", "::"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Convergence", " ", "rate", " ", "near", " ", "t"}], "=", "0.5"}],
    "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"params0", "=", 
     RowBox[{"CVTPulley`TypesAndValidation`MakeParameters", "[", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<rMin\>\"", "->", "10"}], ",", 
        RowBox[{"\"\<rMax\>\"", "->", "30"}], ",", 
        RowBox[{"\"\<d\>\"", "->", "70"}], ",", 
        RowBox[{"\"\<nGrid\>\"", "->", "100"}], ",", 
        RowBox[{"\"\<epsBis\>\"", "->", 
         RowBox[{"10", "^", 
          RowBox[{"-", "12"}]}]}], ",", 
        RowBox[{"\"\<epsSym\>\"", "->", 
         RowBox[{"10", "^", 
          RowBox[{"-", "6"}]}]}], ",", 
        RowBox[{"\"\<workingPrecision\>\"", "->", "30"}], ",", 
        RowBox[{"\"\<exportBaseName\>\"", 
         "->", "\"\<convergence_near_half\>\""}]}], "|>"}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"params", "=", 
     RowBox[{
     "CVTPulley`BeltLength`SetReferenceBeltLength", "[", "params0", "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"symDataConv", "=", 
     RowBox[{"CVTPulley`Symmetrization`SymmetrizationData", "[", 
      RowBox[{"params", ",", 
       RowBox[{"\"\<StoreHistory\>\"", "->", "False"}], ",", 
       RowBox[{"\"\<ImplicitStoreHistory\>\"", "->", "False"}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nConv", "=", 
     RowBox[{"params", "[", "\"\<nGrid\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tGridConv", "=", 
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{"Range", "[", 
        RowBox[{"0", ",", "nConv"}], "]"}], "/", "nConv"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"iterCountsConv", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"Indeterminate", ",", 
       RowBox[{"nConv", "+", "1"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"res", ",", "i", ",", "j"}], "}"}], ",", 
        RowBox[{
         RowBox[{"res", "=", 
          RowBox[{
           RowBox[{"symDataConv", "[", "\"\<PairResults\>\"", "]"}], "[", 
           RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"i", "=", 
          RowBox[{"res", "[", "\"\<PairIndexLeft\>\"", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"j", "=", 
          RowBox[{"res", "[", "\"\<PairIndexRight\>\"", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"iterCountsConv", "[", 
           RowBox[{"[", 
            RowBox[{"i", "+", "1"}], "]"}], "]"}], "=", 
          RowBox[{"res", "[", "\"\<IterationsPerformed\>\"", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"iterCountsConv", "[", 
           RowBox[{"[", 
            RowBox[{"j", "+", "1"}], "]"}], "]"}], "=", 
          RowBox[{"res", "[", "\"\<IterationsPerformed\>\"", "]"}]}], ";"}]}],
        "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", 
        RowBox[{"Length", "[", 
         RowBox[{"symDataConv", "[", "\"\<PairResults\>\"", "]"}], "]"}]}], 
       "}"}]}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"AssociationQ", "[", 
       RowBox[{"symDataConv", "[", "\"\<MidpointResult\>\"", "]"}], "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"iterCountsConv", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"symDataConv", "[", 
            RowBox[{"\"\<MidpointResult\>\"", ",", "\"\<Index\>\""}], "]"}], "+",
            "1"}], "]"}], "]"}], "=", 
        RowBox[{"symDataConv", "[", 
         RowBox[{"\"\<MidpointResult\>\"", 
          ",", "\"\<IterationsPerformed\>\""}], "]"}]}], ";"}]}], "]"}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"convData", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"tGridConv", ",", "iterCountsConv"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"yMaxConv", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"DeleteCases", "[", 
       RowBox[{"iterCountsConv", ",", "Indeterminate"}], "]"}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"figConvNearHalf", "=", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ListLinePlot", "[", 
          RowBox[{"convData", ",", 
           RowBox[{"PlotStyle", "->", 
            RowBox[{"Directive", "[", 
             RowBox[{"Black", ",", 
              RowBox[{"AbsoluteThickness", "[", "1.0", "]"}]}], "]"}]}], ",", 
           RowBox[{"InterpolationOrder", "->", "1"}]}], "]"}], ",", 
         RowBox[{"ListPlot", "[", 
          RowBox[{"convData", ",", 
           RowBox[{"PlotStyle", "->", 
            RowBox[{"Directive", "[", "Black", "]"}]}], ",", 
           RowBox[{"PlotMarkers", "->", 
            RowBox[{"{", 
             RowBox[{"Automatic", ",", "0.012"}], "}"}]}], ",", 
           RowBox[{"Joined", "->", "False"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"Axes", "->", "True"}], ",", 
       RowBox[{"Frame", "->", "False"}], ",", 
       RowBox[{"AxesOrigin", "->", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], ",", 
       RowBox[{"AxesStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", 
          RowBox[{"AbsoluteThickness", "[", "0.8", "]"}]}], "]"}]}], ",", 
       RowBox[{"TicksStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", "12"}], "]"}]}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.05"}], ",", "1.05"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.5"}], ",", 
            RowBox[{"yMaxConv", "+", "1"}]}], "}"}]}], "}"}]}], ",", 
       RowBox[{"PlotRangePadding", "->", 
        RowBox[{"Scaled", "[", "0.02", "]"}]}], ",", 
       RowBox[{"ImageSize", "->", "700"}], ",", 
       RowBox[{"AspectRatio", "->", "0.62"}], ",", 
       RowBox[{"Epilog", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Inset", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{"\"\<t\>\"", ",", "15", ",", "Black", ",", "Italic"}], 
             "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"1.04", ",", 
              RowBox[{"-", "0.5"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"Rotate", "[", 
           RowBox[{
            RowBox[{"Inset", "[", 
             RowBox[{
              RowBox[{"Style", "[", 
               RowBox[{"\"\<iterations\>\"", ",", "15", ",", "Black"}], "]"}],
               ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.06"}], ",", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"yMaxConv", "+", "1"}], ")"}], "/", "2"}]}], 
               "}"}]}], "]"}], ",", 
            RowBox[{"Pi", "/", "2"}]}], "]"}]}], "}"}]}]}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", "figConvNearHalf"}]}]], "Input",
 CellChangeTimes->{{3.9828186533870773`*^9, 3.982818654050535*^9}, {
  3.9828206574580936`*^9, 
  3.9828206599891987`*^9}},ExpressionUUID->"f3190acd-75e7-ba48-9745-\
