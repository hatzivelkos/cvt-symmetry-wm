 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"::", "Section", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"Quick", " ", "sanity", " ", "check"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"params0", "=", 
     RowBox[{"CVTPulley`TypesAndValidation`MakeParameters", "[", 
