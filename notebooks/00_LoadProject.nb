Notebook[{
Cell["\<\

CVTPulley \[LongDash] Load Project

This notebook initializes the local project environment and loads the package
from src/CVTPulley/Kernel/Package.wl.

Expected repository structure:

cvt-symmetry-wm/
  notebooks/
  src/
    CVTPulley/
      Kernel/
        Package.wl
  tests/
  output/

Usage:
1. Open this notebook from the notebooks/ folder.
2. Evaluate the cells below in order.
3. The package will be loaded and ready for use in subsequent notebooks.\
\>", "Text",
 CellChangeTimes->{{3.982768289181795*^9, 
  3.9827683025505867`*^9}},ExpressionUUID->"f9ba541d-0552-7d44-b122-\
d4473fc37dff"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"::", "Section", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"Root", " ", "cell"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"$HistoryLength", "=", "0"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"projectRoot", "=", 
     RowBox[{"ExpandFileName", "@", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<..\>\""}], "}"}], 
       "]"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", 
       RowBox[{"DirectoryQ", "[", "projectRoot", "]"}]}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<[ERROR] Project root not found: \>\"", ",", 
         "projectRoot"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Abort", "[", "]"}], ";"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"notebooksRoot", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"projectRoot", ",", "\"\<notebooks\>\""}], "}"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"srcRoot", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
       "projectRoot", ",", "\"\<src\>\"", ",", "\"\<CVTPulley\>\"", 
        ",", "\"\<Kernel\>\""}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"testsRoot", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"projectRoot", ",", "\"\<tests\>\""}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"outputRoot", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"projectRoot", ",", "\"\<output\>\""}], "}"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"examplesRoot", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"projectRoot", ",", "\"\<examples\>\""}], "}"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"docsRoot", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"projectRoot", ",", "\"\<docs\>\""}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"SetDirectory", "[", "projectRoot", "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Project root:   \>\"", ",", "projectRoot"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Notebook dir:   \>\"", ",", 
      RowBox[{"NotebookDirectory", "[", "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Kernel src dir: \>\"", ",", "srcRoot"}], "]"}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.9827683069413204`*^9, 3.98276833229286*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"f8d241e0-1dc7-ba4c-8175-0ab778376f3c"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"::", "Section", "::"}], "*)"}], 
  RowBox[{"(*", "Loader", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"packageFile", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"srcRoot", ",", "\"\<Package.wl\>\""}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", 
       RowBox[{"DirectoryQ", "[", "srcRoot", "]"}]}], ",", 
