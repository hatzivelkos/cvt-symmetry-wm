  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Data", " ", "for", " ", "Figure", " ", "3"}], ":", 
    RowBox[{"one", " ", "symmetrization", " ", "step"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
