  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Data", " ", "for", " ", "Figure", " ", "6"}], ":", 
    RowBox[{"belt", "-", 
     RowBox[{
     "length", " ", "deviation", " ", "of", " ", "quadratic", " ", 
      "approximation"}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"L0Fig6", "=", 
     RowBox[{"paramsArticle", "[", "\"\<beltLength\>\"", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"fr", "[", "t_", "]"}], ":=", 
     RowBox[{"qRising", "[", "t", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"fR", "[", "t_", "]"}], ":=", 
     RowBox[{"qFalling", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"beltErr", "[", "t_", "]"}], ":=", 
     RowBox[{
      RowBox[{"CVTPulley`BeltLength`BeltLength", "[", 
       RowBox[{
        RowBox[{"fr", "[", "t", "]"}], ",", 
        RowBox[{"fR", "[", "t", "]"}], ",", 
        RowBox[{"paramsArticle", "[", "\"\<d\>\"", "]"}]}], "]"}], "-", 
      "L0Fig6"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"deltaPct", "[", "t_", "]"}], ":=", 
     RowBox[{"100.0", "*", 
      RowBox[{
       RowBox[{"beltErr", "[", "t", "]"}], "/", "L0Fig6"}]}]}], 
    ";"}]}]}]], "Input",
