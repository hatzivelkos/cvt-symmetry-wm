Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"::", "Section", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
   "Grid", " ", "and", " ", "profiles", " ", "for", " ", "Figure", " ", "4"}],
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"symArticle", "=", 
     RowBox[{"CVTPulley`Symmetrization`SymmetrizationData", "[", 
      RowBox[{"paramsArticle", ",", 
       RowBox[{"\"\<StoreHistory\>\"", "->", "False"}], ",", 
       RowBox[{"\"\<ImplicitStoreHistory\>\"", "->", "False"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"FailureQ", "[", "symArticle", "]"}], ",", 
      RowBox[{
       RowBox[{
       "Print", "[", "\"\<[ERROR] SymmetrizationData failed.\>\"", "]"}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "symArticle", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Abort", "[", "]"}]}], ",", 
      RowBox[{
      "Print", "[", "\"\<[OK] Full symmetrization computed.\>\"", "]"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"profilesArticle", "=", 
     RowBox[{
     "CVTPulley`Symmetrization`BuildSymmetricDiscreteProfiles", "[", 
      "symArticle", "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"FailureQ", "[", "profilesArticle", "]"}], ",", 
      RowBox[{
       RowBox[{
       "Print", "[", "\"\<[ERROR] BuildSymmetricDiscreteProfiles failed.\>\"",
         "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "profilesArticle", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Abort", "[", "]"}]}], ",", 
      RowBox[{"Print", "[", "\"\<[OK] Final profiles built.\>\"", "]"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"tGrid4", "=", 
     RowBox[{"profilesArticle", "[", "\"\<tGrid\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rGrid4", "=", 
     RowBox[{"profilesArticle", "[", "\"\<rGrid\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"RGrid4", "=", 
     RowBox[{"profilesArticle", "[", "\"\<RGrid\>\"", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Profile sizes:\>\"", "]"}], ";"}], "\n", 
