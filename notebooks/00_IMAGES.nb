     RowBox[{"mapDataArticle", "[", "\"\<RGrid\>\"", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"r1Curve", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
